{
  "name": "extractor",
  "description": "Extracts structured financial metrics from uploaded documents.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "output_schema": {
    "type": "object",
    "properties": {
      "revenue": {},
      "ebitda": {},
      "yoy_growth": {},
      "customer_concentration": {},
      "legal_risks": {}
    }
  },
  "visibility": "POD",   
  "permissions": {
    "grants": [
      {
        "resource_type": "folder",
