# Lemma ZK Tracer — Verifiable Due Diligence
# Environment configuration
# Copy to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
ANTHROPIC_API_KEY=                    # Optional fallback

# ── Lemma Platform ────────────────────────────────────────────────────────────
LEMMA_API_KEY=                        # Your Lemma workspace API key
OTLP_ENDPOINT=http://localhost:4318   # OpenTelemetry collector endpoint

# ── Cryptographic Layer ───────────────────────────────────────────────────────
# Must be at least 16 chars. In production: use a KMS-managed secret.
PROOF_HMAC_SECRET=change-me-to-something-very-secret-32chars

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=50

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
